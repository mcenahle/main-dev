    <div class="carousel-item">
      <img src="/images/珍珠耳环.png" class="d-block" style="width:100%" />
    </div>
    <div class="carousel-item">
      <img
        src="/images/组合测试-渲染方式对比.jpg"
        class="d-block"
        style="width:100%"
      />
    </div>
    <div class="carousel-item">
      <img src="/images/螺母.png" class="d-block" style="width:100%" />
    </div>
  </div>

