---
import Footer from "./Footer.astro";
import { ClientRouter } from "astro:transitions";
const pathname = Astro.url.pathname;

const editUrl =
  "https://github.com/mcenahle/main-dev/edit/main/src/pages" +
  (pathname === "/" ? "/index.astro" : pathname + ".astro");
---

<!doctype html>
<html lang="zh-CN" class="h-100">
  <head>
    <meta charset="utf-8" />
    <meta name="theme-color" content="#118b1b" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      href="/framework/bootstrap-5.3.8/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script
      is:inline
      src="/framework/bootstrap-5.3.8/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/framework/iconify-icon-3.0.0/iconify-icon.min.js"
    ></script>
    <link href="/main-page-icons.css" rel="stylesheet" />
    <ClientRouter />

    <style>
      @font-face {
        font-family: "JetBrainsMono";
        src: url("https://devdocs.mcenahle.page/fonts/JetBrainsMono-Regular.woff2")
          format("woff2");
        font-weight: 400;
        font-style: normal;
      }

      @font-face {
        font-family: "JetBrainsMono";
        src: url("https://devdocs.mcenahle.page/fonts/JetBrainsMono-Bold.woff2")
          format("woff2");
        font-weight: 700;
        font-style: normal;
      }

      @font-face {
        font-family: "JetBrainsMono";
        src: url("https://devdocs.mcenahle.page/fonts/JetBrainsMono-Italic.woff2")
          format("woff2");
        font-weight: 400;
        font-style: italic;
      }

      @font-face {
        font-family: "JetBrainsMono";
        src: url("https://devdocs.mcenahle.page/fonts/JetBrainsMono-BoldItalic.woff2")
          format("woff2");
        font-weight: 700;
        font-style: italic;
      }

      html,
      body {
        height: 100%;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
        margin-bottom: 40px;
      }

      footer {
        margin-top: auto;
      }

      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-size: cover;
        background-position: center center;
        /* background: linear-gradient(180deg, #a1c4fd 0%, #c2e9fb 100%);
        background: -webkit-linear-gradient(180deg, #a1c4fd 0%, #c2e9fb 100%); */
        background-image: url("/images/1000032162.jpg");
        opacity: 0.15;
        z-index: -1;
        pointer-events: none;
      }

      .card {
        background: rgb(255 255 255 / 0.5);
      }

      .navbar-brand,
      .navbar-toggler {
        margin-left: 12px !important;
        margin-right: 12px !important;
      }

      @media (max-width: 992px) {
        .navbar-nav {
          margin-left: 12px !important;
        }
      }

      .bg-custom {
        background-color: #118b1b;
      }

      .dropdown-item.active,
      .dropdown-item:active {
        color: #fff;
        text-decoration: none;
        background-color: #118b1b;
      }

      .navbar-dark .navbar-toggler {
        color: rgba(255, 255, 255, 0.55);
        border-color: rgba(255, 255, 255, 0.5);
      }

      .container,
      .container-md,
      .container-sm {
        margin-top: 80px;
      }

      @media (max-width: 480px) {
        .container,
        .container-md,
        .container-sm {
          max-width: 740px !important;
        }
      }
    </style>

    <style is:global>
      code {
        font-family: "JetBrainsMono";
        color: black;
      }

      a {
        text-decoration: none;
      }

      .articles p {
        text-indent: 2em;
      }

      .pictures-carousel {
        max-width: 600px;
        margin: 0 auto;
      }

      .carousel-caption {
        color: #fff;
        text-shadow: 0px 2px 8px rgba(0, 0, 0, 0.55);
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-md bg-custom navbar-dark fixed-top">
      <!-- Brand -->
      <a class="navbar-brand" href="/"
        ><img src="/favicon.svg" alt="网站徽标" width="40" height="40" /> mcenahle.dev</a
      >

      <!-- Toggler/collapsibe Button -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#collapsibleNavbar"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Navbar links -->
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav ms-auto me-3">
          <li class="nav-item">
            <a
              class="nav-link"
              href="https://github.com/mcenahle/"
              target="_blank"
              style="display: flex; justify-content: space-between"
              >My GitHub&nbsp;<iconify-icon icon="mdi:external-link"
              ></iconify-icon></a
            >
          </li>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="#"
              id="navbardrop"
              data-bs-toggle="dropdown"
            >
              个人运行的网站
            </a>
            <div
              class="dropdown-menu m-0 border-0 shadow-sm p-2 dropdown-menu-end"
            >
              <a
                class="dropdown-item px-3 py-2 rounded"
                href="https://hi.mcenahle.page"
                target="_blank"
                style="display: flex; justify-content: space-between"
                >个人主页网站 <iconify-icon icon="mdi:external-link"
                ></iconify-icon></a
              >
              <a
                class="dropdown-item px-3 py-2 rounded"
                href="https://blog.mcenahle.page"
                target="_blank"
                style="display: flex; justify-content: space-between"
                >博客网站（梅之夏）<iconify-icon icon="mdi:external-link"
                ></iconify-icon></a
              >
            </div>
          </li>
          <li class="nav-item">
            <a
              class="nav-link"
              href="https://github.com/mcenahle/main-dev/"
              target="_blank"
              style="display: flex; justify-content: space-between; font-size: 22px;"
              ><iconify-icon icon="mdi:github"></iconify-icon></a
            >
          </li>
        </ul>
      </div>
    </nav>
    <main class="container">
      <slot />
    </main>
    <Footer editUrl={editUrl} />
  </body>
</html>
