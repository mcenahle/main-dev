---
interface Props {
  editUrl?: string;
}

const { editUrl } = Astro.props;
---

<footer class="footer mt-auto py-3 bg-body-tertiary">
  <div class="container">
    <span class="text-body-secondary">
      <small
        >{
          editUrl && (
            <a href={editUrl} target="_blank" rel="noopener noreferrer">
              <iconify-icon icon="mdi:edit-outline" />
              &nbsp;
              <u>在 GitHub 上编辑此页</u>
            </a>
          )
        }</small
      >
      <br />
      <div
        class="d-flex flex-column flex-md-row justify-content-between align-items-md-center"
      >
        <div>
          © 2026 mcenahle.dev。本网站不使用 <iconify-icon
            icon="mdi:cookie-remove"></iconify-icon> Cookie。
        </div>

        <div>
          <iconify-icon icon="mdi:email-outline"></iconify-icon> 联系方式：<a
            href="mailto:hi@mcenahle.page"><u>hi@mcenahle.page</u></a
          >。
        </div>
      </div>
      <a href="https://icp.gov.moe/?keyword=20265573" target="_blank"
        ><iconify-icon icon="mdi:verified-user"></iconify-icon>&nbsp;
        <u>萌ICP备20265573号</u>&nbsp;<iconify-icon icon="mdi:external-link"
        ></iconify-icon></a
      >
      <br />
      <a
        href="https://qname.ai/zh/age/mcenahle.dev"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://qname.ai/api/badge/domain-age/mcenahle.dev?theme=green&lang=zh"
          alt="Domain age badge for mcenahle.dev"
        />
      </a></span
    >
  </div>
</footer>
