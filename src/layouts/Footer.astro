---
interface Props {
  editUrl?: string;
}

const { editUrl } = Astro.props;
---

<small class="mt-auto py-4">
  <div class="container">
    {
      editUrl && (
        <a href={editUrl} target="_blank" rel="noopener noreferrer">
          <span class="mdi--edit-outline" />
          &nbsp;
          <u>在 GitHub 上编辑此页</u>
        </a>
      )
    }
  </div>
</small>

<footer class="footer mt-auto py-3 bg-body-tertiary">
  <div class="container">
    <span class="text-body-secondary">
      <b>© 2026 mcenahle.dev。</b><small>本网站为真人设计，AI 辅助开发。</small>
      <br />
      <span class="mdi--cookie-remove"></span> 本网站不使用 Cookie。
      <small><i>We do not use cookies. <b>We eat apples instead.</b></i></small>
      <br />
      <div
        class="d-flex flex-column flex-md-row justify-content-between align-items-md-center"
      >
        <div>
          <span class="mdi--verified-user"></span> 备案信息：<a
            href="https://icp.gov.moe/?keyword=20265573"
            target="_blank"
          >
            <u>萌ICP备20265573号</u>&nbsp;<span class="mdi--external-link"
            ></span></a
          >
        </div>

        <div>
          <span class="mdi--email-outline"></span>&nbsp;
          <a href="mailto:hi@mcenahle.page"><u>hi@mcenahle.page</u></a>
        </div>
      </div>

      <a
        href="https://qname.ai/zh/age/mcenahle.dev"
        target="_blank"
        rel="noreferrer"
      >
        <img
          src="https://qname.ai/api/badge/domain-age/mcenahle.dev?theme=green&lang=zh"
          alt="Domain age badge for mcenahle.dev"
        />
      </a>

      <br />

      <div
        title="MySSL 安全签章"
        id="myssl_seal"
        onclick="window.open('https://myssl.com/seal/detail?domain=mcenahle.dev','MySSL安全签章','height=800,width=470,top=0,right=0,toolbar=no,menubar=no,scrollbars=no,resizable=no,location=no,status=no')"
        style="text-align: center"
      >
        <img
          src="/images/seal-ssl.svg"
          alt="MySSL 安全签章"
          style="width: 100px; height: auto; cursor: pointer"
        />
      </div>
    </span>
  </div>
</footer>
